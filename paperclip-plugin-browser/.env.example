# Outlook on the web entry point.
OUTLOOK_URL=https://outlook.office.com/mail/

# Hosts the agent may operate on. It refuses to act anywhere else.
BROWSER_ALLOWED_HOSTS=outlook.office.com,outlook.office365.com

# Dedicated, isolated browser profile (NOT your normal browser). You sign in here once.
BROWSER_PROFILE_DIR=

# Run headed (false) so you can watch it. Set true only once you trust a flow.
BROWSER_HEADLESS=false

# Model Stagehand uses to locate elements. A local Ollama model keeps page
# content on-device; or use an OpenRouter/Anthropic model id.
BROWSER_MODEL=ollama/llama3.1

# Master kill-switch for any outbound/destructive action. Leave false.
BROWSER_ALLOW_SIDE_EFFECTS=false

BROWSER_VERBOSE=1
